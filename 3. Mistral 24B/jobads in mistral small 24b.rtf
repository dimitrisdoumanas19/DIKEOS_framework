### \uc0\u916 \u953 \u959 \u961 \u952 \u969 \u956 \u941 \u957 \u959  \u922 \u949 \u943 \u956 \u949 \u957 \u959 \
\
**AD1: \uc0\u908 \u964 \u945 \u957  \u948 \u953 \u945 \u955 \u941 \u947 \u959 \u965 \u956 \u949  \u964 \u945  \u965 \u955 \u953 \u954 \u940  \u956 \u945 \u962  \u963 \u964 \u951 \u957  \u913 \u961 \u964 \u959 \u946 \u953 \u959 \u956 \u951 \u967 \u945 \u957 \u943 \u945  \u922 \u913 \u929 \u913 \u924 \u927 \u923 \u917 \u915 \u922 \u927 \u931 , \
\uc0\u949 \u960 \u953 \u955 \u941 \u947 \u959 \u965 \u956 \u949  \u972 ,\u964 \u953  \u960 \u953 \u959  \u945 \u947 \u957 \u972  \u954 \u945 \u953  \u966 \u965 \u963 \u953 \u954 \u972  \u941 \u967 \u949 \u953  \u957 \u945  \u956 \u945 \u962  \u960 \u961 \u959 \u963 \u966 \u941 \u961 \u949 \u953  \u951  \u966 \u973 \u963 \u951 . \u932 \u959  \
\uc0\u945 \u955 \u949 \u973 \u961 \u953 , \u964 \u959  \u957 \u949 \u961 \u972 , \u964 \u959  \u945 \u955 \u940 \u964 \u953  \u954 \u945 \u953  \u964 \u959  \u960 \u961 \u959 \u950 \u973 \u956 \u953 , \u945 \u965 \u964 \u940  \u949 \u943 \u957 \u945 \u953  \u959 \u953  \u954 \u973 \u961 \u953 \u949 \u962  \u960 \u961 \u974 \u964 \u949 \u962  \u973 \u955 \u949 \u962  \
\uc0\u964 \u959 \u965  \u968 \u969 \u956 \u953 \u959 \u973  \u956 \u945 \u962 . \u932 \u959  \u954 \u973 \u961 \u953 \u959  \u963 \u965 \u963 \u964 \u945 \u964 \u953 \u954 \u972  \u964 \u951 \u962  \u949 \u960 \u953 \u964 \u965 \u967 \u943 \u945 \u962  \u956 \u945 \u962  \u969 \u963 \u964 \u972 \u963 \u959  \u949 \u943 \u957 \u945 \u953  \u959 \u953  \
\uc0\u940 \u957 \u952 \u961 \u969 \u960 \u959 \u953  \u956 \u945 \u962  \u954 \u945 \u953  \u951  \u949 \u960 \u953 \u955 \u959 \u947 \u942  \u964 \u959 \u965 \u962  \u949 \u943 \u957 \u945 \u953  \u947 \u953 \u945  \u949 \u956 \u940 \u962  \u949 \u958 \u943 \u963 \u959 \u965  \u963 \u959 \u946 \u945 \u961 \u942  \u965 \u960 \u972 \u952 \u949 \u963 \u951 . \u931 \u964 \u959  \
\uc0\u960 \u955 \u945 \u943 \u963 \u953 \u959  \u964 \u951 \u962  \u948 \u965 \u957 \u945 \u956 \u953 \u954 \u942 \u962  \u956 \u945 \u962  \u945 \u957 \u940 \u960 \u964 \u965 \u958 \u951 \u962  \u945 \u957 \u945 \u950 \u951 \u964 \u959 \u973 \u956 \u949  \u957 \u945  \u960 \u961 \u959 \u963 \u955 \u940 \u946 \u959 \u965 \u956 \u949  \u940 \u956 \u949 \u963 \u945  \u947 \u953 \u945  \u964 \u959  \
\uc0\u949 \u961 \u947 \u959 \u963 \u964 \u940 \u963 \u953 \u959  \u956 \u945 \u962  \u963 \u964 \u959  \u922 \u959 \u961 \u969 \u960 \u943  \u913 \u964 \u964 \u953 \u954 \u942 \u962  : \u917 \u961 \u947 \u940 \u964 \u949 \u962 /\u964 \u961 \u953 \u945 \u962  \u928 \u945 \u961 \u945 \u947 \u969 \u947 \u942 \u962  & \u931 \u965 \u963 \u954 \u949 \u965 \u945 \u963 \u943 \u945 \u962  \
\uc0\u914 \u945 \u963 \u953 \u954 \u940  \u954 \u945 \u952 \u942 \u954 \u959 \u957 \u964 \u945 : \u931 \u965 \u956 \u956 \u949 \u964 \u959 \u967 \u942  \u963 \u964 \u951 \u957  \u949 \u973 \u961 \u965 \u952 \u956 \u951  \u955 \u949 \u953 \u964 \u959 \u965 \u961 \u947 \u943 \u945  \u964 \u951 \u962  \u960 \u945 \u961 \u945 \u947 \u969 \u947 \u953 \u954 \u942 \u962  \
\uc0\u948 \u953 \u945 \u948 \u953 \u954 \u945 \u963 \u943 \u945 \u962  \u963 \u964 \u959  \u960 \u972 \u963 \u964 \u959  \u949 \u965 \u952 \u973 \u957 \u951 \u962  \u964 \u959 \u965 \u962 . \u922 \u945 \u952 \u945 \u961 \u953 \u963 \u956 \u972 \u962  \u954 \u945 \u953  \u963 \u965 \u957 \u964 \u942 \u961 \u951 \u963 \u951  \u964 \u969 \u957  \
\uc0\u956 \u951 \u967 \u945 \u957 \u951 \u956 \u940 \u964 \u969 \u957  \u954 \u945 \u953  \u964 \u959 \u965  \u967 \u974 \u961 \u959 \u965  \u949 \u965 \u952 \u973 \u957 \u951 \u962  \u964 \u959 \u965 \u962 . \u913 \u960 \u945 \u961 \u945 \u943 \u964 \u951 \u964 \u945  \u960 \u961 \u959 \u963 \u972 \u957 \u964 \u945  & \u948 \u949 \u958 \u953 \u972 \u964 \u951 \u964 \u949 \u962 : \
\uc0\u917 \u960 \u953 \u952 \u965 \u956 \u951 \u964 \u942  \u963 \u967 \u949 \u964 \u953 \u954 \u942  \u949 \u961 \u947 \u945 \u963 \u953 \u945 \u954 \u942  \u949 \u956 \u960 \u949 \u953 \u961 \u943 \u945 . \u917 \u961 \u947 \u945 \u964 \u953 \u954 \u972 \u964 \u951 \u964 \u945  \u954 \u945 \u953  \u963 \u965 \u957 \u941 \u960 \u949 \u953 \u945 . \
